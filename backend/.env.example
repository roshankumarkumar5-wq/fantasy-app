# Supabase project settings (Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Used to sign our own JWTs for login sessions
JWT_SECRET=change-this-to-a-long-random-string

# SMS provider for OTP delivery (signup verification + password reset).
# Leave these blank while testing - codes will just be logged to the
# server console instead of actually being texted. Once you've picked
# a provider (see backend/utils/sms.js for notes on a few options),
# fill these in with that provider's actual API URL and key, and update
# the request body/headers inside sendSms() in sms.js to match their API.
SMS_API_URL=
SMS_API_KEY=

PORT=4000
