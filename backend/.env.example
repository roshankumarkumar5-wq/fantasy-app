# Supabase project settings (Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to sign our own JWTs for login sessions
JWT_SECRET=change-this-to-a-long-random-string

# Resend (https://resend.com) - free tier for sending verification/reset emails.
# Sign up free, go to API Keys, create one, paste it here.
# NOTE: on the free tier (before you verify your own domain in Resend), you can
# only send TO the email address you signed up to Resend with. Fine for testing;
# verify a domain in Resend's dashboard before going live with real users.
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=onboarding@resend.dev

PORT=4000
